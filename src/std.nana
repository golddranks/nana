(
    Array = core.Array,
    String = core.String,
    Int = core.Int,
    Float = core.Float,
    Bool = core.Bool,
    Char = core.Char,
    Byte = core.Byte,
    Unit = core.Unit,
    I32 = core.I32,
    F32 = core.F32,

    int_methods = _int_methods,
    float_methods = _float_methods,
    bool_methods = _bool_methods,
    char_methods = _char_methods,
    byte_methods = _byte_methods,
    unit_methods = _unit_methods,
    array_methods = _array_methods,
    string_methods = _string_methods,
    i32_methods = _i32_methods,
    f32_methods = _f32_methods,

    prelude = (
        int_methods = _int_methods,
        float_methods = _float_methods,
        bool_methods = _bool_methods,
        char_methods = _char_methods,
        byte_methods = _byte_methods,
        unit_methods = _unit_methods,
        array_methods = _array_methods,
        string_methods = _string_methods,
        i32_methods = _i32_methods,
        f32_methods = _f32_methods,
    ),

    not = core.not,
    and = core.and,
    or = core.or,
    print = core.print,
    byte = core.byte,
    int = core.int,
    float = core.float,
    char = core.char,
    i32 = core.i32,
    f32 = core.f32,
    ref_eq = core.ref_eq,
