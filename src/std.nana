use(core);

let method_set = core.method_set;

let _int_methods = method_set(core.Int, (
    add = core.int_add,
    subtract = core.int_subtract,
    times = core.int_times,
    divided_by = core.int_divided_by,
    negate = core.int_negate,
    eq = core.int_eq,
    not_eq = core.int_not_eq,
    lt = core.int_lt,
    gt = core.int_gt,
    lt_eq = core.int_lt_eq,
    gt_eq = core.int_gt_eq,
    to_string = core.int_to_string,
    to_float = core.int_to_float,
    to_byte = core.int_to_byte,
    to_char = core.int_to_char,
    to_i32 = core.int_to_i32,
));

let _float_methods = method_set(core.Float, (
    add = core.float_add,
