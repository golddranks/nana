    lt_eq = core.float_lt_eq,
    gt_eq = core.float_gt_eq,
    to_string = core.float_to_string,
    ceil = core.float_ceil,
    floor = core.float_floor,
    round = core.float_round,
    trunc = core.float_trunc,
    to_f32 = core.float_to_f32,
));

